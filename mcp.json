{
	"servers": {
		"sequentialthinking": {
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"-i",
				"mcp/sequentialthinking"
			],
			"type": "stdio"
		},
		"context7": {
			"command": "/bin/bash",
			"args": [
				"-c",
				"npx -y @upstash/context7-mcp@latest"
			],
			"type": "stdio"
		}
	},
	"inputs": [
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	]
}
