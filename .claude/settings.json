{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MCP_TIMEOUT": "60000"
  },
  "permissions": {
    "allow": [
      "Bash(ansible *)",
      "Bash(ansible-galaxy *)",
      "Bash(ansible-playbook *)",
      "Bash(ansible-vault *)",
      "Bash(awk *)",
      "Bash(basename *)",
      "Bash(brew *)",
      "Bash(cargo *)",
      "Bash(cat *)",
      "Bash(chmod *)",
      "Bash(cd *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(defaults *)",
      "Bash(df *)",
      "Bash(diff *)",
      "Bash(dig *)",
      "Bash(dirname *)",
      "Bash(docker *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(env *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(kill *)",
      "Bash(launchctl *)",
      "Bash(ln *)",
      "Bash(ls *)",
      "Bash(lsof *)",
      "Bash(make *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(nc *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(nslookup *)",
      "Bash(nvm *)",
      "Bash(open *)",
      "Bash(openssl rand *)",
      "Bash(osascript *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(ping *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pkill *)",
      "Bash(plutil *)",
      "Bash(ps *)",
      "Bash(pwd)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(rm *)",
      "Bash(rustc *)",
      "Bash(rustup *)",
      "Bash(sed *)",
      "Bash(shasum *)",
      "Bash(sleep *)",
      "Bash(sort *)",
      "Bash(source *)",
      "Bash(ssh *)",
      "Bash(stat *)",
      "Bash(sw_vers *)",
      "Bash(tail *)",
      "Bash(tar *)",
      "Bash(tee *)",
      "Bash(touch *)",
      "Bash(tr *)",
      "Bash(uname *)",
      "Bash(unzip *)",
      "Bash(uuidgen)",
      "Bash(uv *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs *)",
      "Bash(yarn *)",
      "Bash(zip *)",
      "Bash(zsh *)",
      "Read(//Users/**)",
      "Read(//opt/homebrew/**)",
      "Read(//usr/local/**)",
      "Read(~/**)",
      "Read(~/.ssh/*.pub)",
      "Read(~/.ssh/config)",
      "Read(~/.ssh/known_hosts)",
      "WebFetch",
      "WebSearch",
      "mcp__chrome-devtools__*",
      "mcp__context7__*",
      "mcp__docker__*",
      "mcp__figma__*",
      "mcp__firecrawl-mcp__*",
      "mcp__github__*",
      "mcp__playwright__*",
      "mcp__sequentialthinking__*",
      "Bash(wait bj9h03s3o:*)",
      "Bash(rsync -a --exclude='node_modules' --exclude='.git' --exclude='tsconfig.*.tsbuildinfo' --exclude='tsconfig.tsbuildinfo' /Users/dalepaux/WebServer/fiba/R2D2_Front-ui/ /Users/dalepaux/WebServer/fiba/refactored-front-ui/)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Edit(~/.ssh/**)",
      "Read(~/.ssh/**)",
      "Write(~/.ssh/**)"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": [
      "/Users"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your attention\" with title \"Claude Code\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/format.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/enforce-bash-permissions.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "feedbackSurveyRate": 0,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "effortLevel": "max"
}
