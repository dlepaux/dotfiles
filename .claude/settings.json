{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your attention\" with title \"Claude Code\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/format.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-env.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ansible *)",
      "Bash(ansible-galaxy *)",
      "Bash(ansible-playbook *)",
      "Bash(ansible-vault *)",
      "Bash(brew *)",
      "Bash(cargo *)",
      "Bash(cat *)",
      "Bash(chmod *)",
      "Bash(composer *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(diff *)",
      "Bash(dig *)",
      "Bash(docker *)",
      "Bash(drush *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(lsof *)",
      "Bash(make *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(nc *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(nslookup *)",
      "Bash(nvm *)",
      "Bash(openssl rand *)",
      "Bash(osascript *)",
      "Bash(ping *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(rustc *)",
      "Bash(rustup *)",
      "Bash(sed *)",
      "Bash(shasum *)",
      "Bash(sleep *)",
      "Bash(sort *)",
      "Bash(source *)",
      "Bash(ssh *)",
      "Bash(tail *)",
      "Bash(tee *)",
      "Bash(touch *)",
      "Bash(uuidgen)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(zsh *)",
      "Read(//Users/**)",
      "Read(//opt/homebrew/**)",
      "Read(//usr/local/**)",
      "Read(~/**)",
      "WebFetch",
      "WebSearch",
      "mcp__chrome-devtools__*",
      "mcp__context7__*",
      "mcp__docker__*",
      "mcp__figma__*",
      "mcp__firecrawl-mcp__*",
      "mcp__github__*",
      "mcp__playwright__*",
      "mcp__sequentialthinking__*"
    ],
    "deny": []
  },
  "effortLevel": "max"
}
