{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(nvm:*)",
      "Bash(docker:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(rustup:*)",
      "Bash(go:*)",
      "Bash(composer:*)",
      "Bash(php:*)",
      "Bash(drush:*)",
      "Bash(brew:*)",
      "Bash(make:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(jq:*)",
      "Bash(file:*)",
      "Bash(chmod:*)",
      "Bash(uuidgen)",
      "Bash(openssl rand:*)",
      "Read(~/**)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__*",
      "mcp__figma__*",
      "mcp__sequentialthinking__*",
      "mcp__github__*",
      "mcp__playwright__*",
      "mcp__docker__*",
      "mcp__firecrawl-mcp__*",
      "mcp__chrome-devtools__*"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/format.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-env.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your attention\" with title \"Claude Code\"'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
